# Sanity CMS Configuration
# Get these values from your Sanity project dashboard at https://sanity.io/manage

# Your Sanity Project ID
VITE_SANITY_PROJECT_ID=your-project-id-here

# Your Sanity Dataset (usually 'production')
VITE_SANITY_DATASET=production

# Optional: Sanity API Token (for authenticated requests)
# VITE_SANITY_TOKEN=your-token-here

# EmailJS Configuration
# Get these values from your EmailJS dashboard at https://www.emailjs.com/

# Your EmailJS Service ID
VITE_EMAILJS_SERVICE_ID=your-service-id-here

# Your EmailJS Template ID
VITE_EMAILJS_TEMPLATE_ID=your-template-id-here

# Your EmailJS Public Key (User ID)
VITE_EMAILJS_PUBLIC_KEY=your-public-key-here

# Upstash Redis Configuration for the visitor counter
# These stay server-side on Vercel because they do not use the VITE_ prefix.
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Optional: add a server-only salt to strengthen the SHA-256 IP hash.
VISITOR_COUNTER_HASH_SALT=replace-with-a-random-secret

# Optional: simulate the visitor counter while running `npm run dev`.
# This is only read by the frontend in local Vite development.
VITE_DEV_VISITOR_COUNT=1234
